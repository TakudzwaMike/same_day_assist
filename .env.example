# Same Day Assist — Production Environment Template

# Port configuration
PORT=5000

# Client Application URL
CLIENT_URL=http://localhost:3000

# JWT Secrets (Generate secure random keys in production)
JWT_ACCESS_SECRET=sda-access-secret-key-12345
JWT_REFRESH_SECRET=sda-refresh-secret-key-67890

# Storage Config
UPLOADS_DIR=./uploads

# Staging/Production PostgreSQL URL (Uncomment for production migrations)
# DATABASE_URL="postgresql://db_user:db_password@localhost:5432/samedayassist?schema=public"

# Administrative Registration Secrets
ADMIN_REGISTRATION_SECRET=
SUPER_ADMIN_SECRET=
